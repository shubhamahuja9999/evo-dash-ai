// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User management
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      UserRole @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  campaigns     Campaign[]
  analytics     Analytics[]
  apiKeys      ApiKey[]
  aiRecommendations AIRecommendation[]
  cuaCommands  CUACommand[]
  cuaUserAccess CUAUserAccess[]
  cuaAudits    CUAAudit[]
  crmIntegrations CRMIntegration[]
  accountAlerts AccountAlert[]
  budgetRules  BudgetRule[]
  
  @@map("users")
}

enum UserRole {
  ADMIN
  USER
  MANAGER
}

// Google Ads API configuration
model ApiKey {
  id        String   @id @default(cuid())
  name      String
  key       String
  isActive  Boolean  @default(true)
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("api_keys")
}

// Campaign management
model Campaign {
  id          String   @id @default(cuid())
  name        String
  status      CampaignStatus @default(ACTIVE)
  budget      Float?
  startDate   DateTime?
  endDate     DateTime?
  targetAudience String?
  userId      String
  googleAdsId String?  @unique // Google Ads campaign ID - unique constraint
  campaignType String? // SEARCH, DISPLAY, VIDEO, etc.
  optimizationScore Float? // Google Ads optimization score
  bidStrategy String? // Bidding strategy type
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  adGroups    AdGroup[]
  analytics   Analytics[]
  aiRecommendations AIRecommendation[]
  leads       Lead[]
  keywords    Keyword[]
  
  @@map("campaigns")
}

enum CampaignStatus {
  ACTIVE
  PAUSED
  ENDED
  DRAFT
}

// Ad Groups
model AdGroup {
  id          String   @id @default(cuid())
  name        String
  status      AdGroupStatus @default(ACTIVE)
  campaignId  String
  googleAdsId String?  // Google Ads ad group ID
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  ads        Ad[]
  leads      Lead[]
  keywords   Keyword[]
  
  @@map("ad_groups")
}

enum AdGroupStatus {
  ACTIVE
  PAUSED
  REMOVED
}

// Ads
model Ad {
  id          String   @id @default(cuid())
  name        String
  type        AdType
  status      AdStatus @default(ACTIVE)
  headline1   String?
  headline2   String?
  headline3   String?
  description String?
  finalUrl    String?
  adGroupId   String
  googleAdsId String?  // Google Ads ad ID
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  adGroup     AdGroup @relation(fields: [adGroupId], references: [id], onDelete: Cascade)
  leads       Lead[]
  
  @@map("ads")
}

enum AdType {
  RESPONSIVE_SEARCH_AD
  TEXT_AD
  IMAGE_AD
  VIDEO_AD
}

enum AdStatus {
  ACTIVE
  PAUSED
  REMOVED
  UNDER_REVIEW
}

// Analytics and performance data
model Analytics {
  id                  String   @id @default(cuid())
  date                DateTime
  impressions         Int      @default(0)
  activeViewImpressions Int      @default(0)
  clicks              Int      @default(0)
  interactions        Int      @default(0)
  cost                Float    @default(0)
  conversions         Int      @default(0)
  allConversions      Int      @default(0)
  conversionValue     Float    @default(0)
  allConversionValue  Float    @default(0)
  ctr                 Float?   // Click-through rate
  activeViewCtr       Float?   // Active View click-through rate
  interactionRate     Float?   // Interaction rate
  cpc                 Float?   // Cost per click
  cpv                 Float?   // Cost per view
  cpm                 Float?   // Cost per thousand impressions
  costPerConversion   Float?   // Cost per conversion
  costPerAllConversion Float?  // Cost per all conversions
  userId              String?
  campaignId          String?
  createdAt           DateTime @default(now())
  
  // Relations
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  campaign    Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  
  @@map("analytics")
}

// AI recommendations and insights
model AIRecommendation {
  id          String   @id @default(cuid())
  type        RecommendationType
  title       String
  description String
  content     String?  // JSON content of the recommendation
  metadata    Json?    // Additional metadata like category, source, etc.
  confidence  Int?     @default(0) // Confidence score 0-100
  priority    Priority @default(MEDIUM)
  isApplied   Boolean  @default(false)
  campaignId  String?
  userId      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  campaign    Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  @@map("ai_recommendations")
}

enum RecommendationType {
  BUDGET_OPTIMIZATION
  KEYWORD_OPTIMIZATION
  AD_COPY_IMPROVEMENT
  TARGETING_REFINEMENT
  PERFORMANCE_ANALYSIS
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// Audit logs
model AuditLog {
  id          String   @id @default(cuid())
  action      String
  entityType  String
  entityId    String?
  oldValues   Json?
  newValues   Json?
  userId      String?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
  
  @@map("audit_logs")
}

// Google Ads CUA (Customer User Access) management
model CUACommand {
  id          String   @id @default(cuid())
  command     String   // Natural language command
  action      CUAAction
  status      CUACommandStatus @default(PENDING)
  email       String?  // Target email for user operations
  accessLevel String?  // Access level for invite/update operations
  result      Json?    // Command execution result
  error       String?  // Error message if failed
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("cua_commands")
}

enum CUAAction {
  INVITE_USER
  UPDATE_ACCESS
  REMOVE_ACCESS
  AUDIT
}

enum CUACommandStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// Google Ads CUA User Access Records
model CUAUserAccess {
  id          String   @id @default(cuid())
  email       String   @unique
  accessLevel String
  status      String
  lastAccess  DateTime?
  userId      String   // User who manages this access
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("cua_user_access")
}

// Google Ads CUA Audit Records
model CUAAudit {
  id          String   @id @default(cuid())
  findings    Json     // Audit findings and recommendations
  riskLevel   String
  userId      String
  createdAt   DateTime @default(now())
  
  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("cua_audits")
}

// CRM Integration Models
model CRMIntegration {
  id            String   @id @default(cuid())
  name          String   // CRM name (Salesforce, HubSpot, etc.)
  type          CRMType
  apiKey        String?  @map("api_key")
  apiSecret     String?  @map("api_secret")
  accessToken   String?  @map("access_token")
  refreshToken  String?  @map("refresh_token")
  instanceUrl   String?  @map("instance_url")
  isActive      Boolean  @default(true)
  lastSyncAt    DateTime? @map("last_sync_at")
  userId        String   @map("user_id")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Relations
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  leads         Lead[]
  
  @@map("crm_integrations")
}

enum CRMType {
  SALESFORCE
  HUBSPOT
  PIPEDRIVE
  ZOHO
  CUSTOM
}

// Lead Management
model Lead {
  id                String   @id @default(cuid())
  crmLeadId         String?  @map("crm_lead_id") // Original CRM ID
  email             String?
  phone             String?
  firstName         String?  @map("first_name")
  lastName          String?  @map("last_name")
  company           String?
  jobTitle          String?  @map("job_title")
  leadSource        String?  @map("lead_source")
  leadScore         Float?   @map("lead_score") // CRM lead score
  
  // Campaign Attribution
  campaignId        String?  @map("campaign_id")
  adGroupId         String?  @map("ad_group_id")
  adId              String?  @map("ad_id")
  keyword           String?  // Keyword that generated the lead
  landingPage       String?  @map("landing_page")
  utmSource         String?  @map("utm_source")
  utmMedium         String?  @map("utm_medium")
  utmCampaign       String?  @map("utm_campaign")
  utmTerm           String?  @map("utm_term")
  utmContent        String?  @map("utm_content")
  gclid             String?  // Google Click ID
  
  // Lead Quality & Performance
  qualityScore      Float?   @map("quality_score") // ML-generated quality score (0-1)
  conversionValue   Float?   @map("conversion_value")
  conversionType    String?  @map("conversion_type")
  leadStage         LeadStage @default(NEW)
  isQualified       Boolean? @map("is_qualified")
  
  // Timestamps
  firstTouchAt      DateTime? @map("first_touch_at")
  lastTouchAt       DateTime? @map("last_touch_at")
  convertedAt       DateTime? @map("converted_at")
  qualifiedAt       DateTime? @map("qualified_at")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // Relations
  campaign          Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  adGroup           AdGroup?  @relation(fields: [adGroupId], references: [id], onDelete: SetNull)
  ad                Ad?       @relation(fields: [adId], references: [id], onDelete: SetNull)
  crmIntegration    CRMIntegration? @relation(fields: [crmIntegrationId], references: [id], onDelete: SetNull)
  crmIntegrationId  String?   @map("crm_integration_id")
  leadActivities    LeadActivity[]
  qualityPredictions MLPrediction[]
  
  @@map("leads")
}

enum LeadStage {
  NEW
  CONTACTED
  QUALIFIED
  OPPORTUNITY
  CUSTOMER
  LOST
}

// Lead Activity Tracking
model LeadActivity {
  id          String   @id @default(cuid())
  leadId      String   @map("lead_id")
  activityType ActivityType @map("activity_type")
  description String?
  metadata    Json?    // Additional activity data
  timestamp   DateTime
  createdAt   DateTime @default(now())
  
  // Relations
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  
  @@map("lead_activities")
}

enum ActivityType {
  FORM_SUBMISSION
  PHONE_CALL
  EMAIL_SENT
  EMAIL_OPENED
  EMAIL_CLICKED
  WEBSITE_VISIT
  DEMO_REQUEST
  MEETING_SCHEDULED
  PROPOSAL_SENT
  DEAL_CLOSED
}

// ML Models and Predictions
model MLModel {
  id          String   @id @default(cuid())
  name        String
  type        MLModelType
  version     String
  filePath    String?  @map("file_path")
  accuracy    Float?
  isActive    Boolean  @default(false)
  metadata    Json?    // Model parameters, features, etc.
  trainedAt   DateTime? @map("trained_at")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  predictions MLPrediction[]
  
  @@map("ml_models")
}

enum MLModelType {
  LEAD_QUALITY_SCORING
  CONVERSION_PREDICTION
  BUDGET_OPTIMIZATION
  BID_OPTIMIZATION
  KEYWORD_PERFORMANCE
  AD_PERFORMANCE
}

model MLPrediction {
  id          String   @id @default(cuid())
  modelId     String   @map("model_id")
  entityType  String   @map("entity_type") // 'lead', 'campaign', 'keyword', etc.
  entityId    String   @map("entity_id")
  prediction  Float    // Predicted value/score
  confidence  Float?   // Confidence score (0-1)
  features    Json?    // Input features used for prediction
  createdAt   DateTime @default(now())
  
  // Relations
  model       MLModel  @relation(fields: [modelId], references: [id], onDelete: Cascade)
  lead        Lead?    @relation(fields: [entityId], references: [id], onDelete: Cascade)
  
  @@map("ml_predictions")
}

// Keyword Management
model Keyword {
  id               String   @id @default(cuid())
  text             String
  matchType        MatchType @map("match_type")
  campaignId       String?   @map("campaign_id")
  adGroupId        String?   @map("ad_group_id")
  status           KeywordStatus @default(ACTIVE)
  maxCpc           Float?    @map("max_cpc") // Max cost per click bid
  qualityScore     Int?      @map("quality_score") // Google Ads quality score (1-10)
  
  // Performance metrics
  impressions      Int       @default(0)
  clicks           Int       @default(0)
  cost             Float     @default(0)
  conversions      Int       @default(0)
  conversionValue  Float     @default(0) @map("conversion_value")
  
  // ML insights
  performanceScore Float?    @map("performance_score") // ML-generated performance score
  isNegative       Boolean   @default(false) @map("is_negative")
  
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  
  // Relations
  campaign         Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  adGroup          AdGroup?  @relation(fields: [adGroupId], references: [id], onDelete: SetNull)
  
  @@map("keywords")
}

enum MatchType {
  EXACT
  PHRASE
  BROAD
  BROAD_MODIFIED
}

enum KeywordStatus {
  ACTIVE
  PAUSED
  REMOVED
}

// Account Management
model AccountAlert {
  id          String      @id @default(cuid())
  type        AlertType
  severity    AlertSeverity
  title       String
  message     String
  metadata    Json?       // Additional alert data
  isResolved  Boolean     @default(false) @map("is_resolved")
  resolvedAt  DateTime?   @map("resolved_at")
  userId      String      @map("user_id")
  createdAt   DateTime    @default(now())
  
  // Relations
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("account_alerts")
}

enum AlertType {
  BILLING_ISSUE
  SPEND_LIMIT_REACHED
  PERFORMANCE_DROP
  QUALITY_SCORE_DROP
  ACCOUNT_SUSPENDED
  API_ERROR
  CRM_SYNC_FAILED
}

enum AlertSeverity {
  INFO
  WARNING
  ERROR
  CRITICAL
}

// Budget Management
model BudgetRule {
  id          String   @id @default(cuid())
  name        String
  type        BudgetRuleType @map("rule_type")
  condition   Json     // Rule conditions (spend thresholds, performance metrics, etc.)
  action      Json     // Actions to take (pause campaigns, adjust budgets, etc.)
  isActive    Boolean  @default(true) @map("is_active")
  userId      String   @map("user_id")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("budget_rules")
}

enum BudgetRuleType {
  DAILY_SPEND_LIMIT
  COST_PER_LEAD_LIMIT
  ROAS_THRESHOLD
  PERFORMANCE_BASED
}

// Search Cache for server-side search API
model SearchCache {
  id          String   @id @default(cuid())
  cacheKey    String   @unique // Unique key for the search query
  query       String   // Original search query
  siteRestrict String?  // Site restriction if any
  results     Json     // Cached search results
  provider    String   // Search API provider used
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("search_cache")
}


